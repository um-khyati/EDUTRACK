<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.edutrack.controller.TeacherDashboardController">

    <left>
        <VBox prefWidth="220.0" spacing="30.0" styleClass="sidebar">
            <padding>
                <Insets bottom="30.0" left="25.0" right="25.0" top="40.0"/>
            </padding>
            <Label text="EduTrack" styleClass="sidebar-title" />
            <Label text="Teacher Portal" style="-fx-text-fill: #94a3b8; -fx-font-size: 14px;" />
            
            <Region VBox.vgrow="ALWAYS"/>
            
            <Button maxWidth="Infinity" onAction="#handleLogout" styleClass="btn-danger" text="Logout" />
        </VBox>
    </left>

    <center>
        <ScrollPane fitToWidth="true" style="-fx-faint-focus-color: transparent; -fx-focus-color: transparent;">
            <VBox spacing="25.0">
                <padding>
                    <Insets bottom="40.0" left="40.0" right="40.0" top="40.0"/>
                </padding>

                <Label text="Student Roster &amp; Management" style="-fx-font-size: 32px; -fx-font-weight: 800; -fx-text-fill: #1e293b;"/>

                <VBox spacing="10.0" styleClass="card">
                    <HBox alignment="CENTER_LEFT">
                        <Label text="My Students" style="-fx-font-weight: bold; -fx-text-fill: #0f172a; -fx-font-size: 18px;"/>
                        <Region HBox.hgrow="ALWAYS" />
                        <Button onAction="#handleMarkPresent" minWidth="-Infinity" styleClass="btn-success" text="Mark Present" />
                        <Region prefWidth="10.0" />
                        <Button onAction="#handleMarkAbsent" minWidth="-Infinity" styleClass="btn-danger" text="Mark Absent" />
                    </HBox>
                    
                    <TableView fx:id="studentTable" prefHeight="250.0">
                        <columns>
                            <TableColumn fx:id="colId" maxWidth="80.0" minWidth="50.0" text="ID" />
                            <TableColumn fx:id="colName" text="Student Name" />
                            <TableColumn fx:id="colEmail" text="Student Email" />
                            <TableColumn fx:id="colCourse" text="Enrolled Course" />
                        </columns>
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                        </columnResizePolicy>
                    </TableView>
                </VBox>

                <HBox alignment="CENTER_LEFT" spacing="15.0" styleClass="card">
                    <Label text="Assign Grade:" minWidth="-Infinity" style="-fx-font-weight: bold; -fx-text-fill: #64748b; -fx-font-size: 15px;"/>
                    <TextField fx:id="subjectField" promptText="Subject Name (e.g., Java)" prefWidth="250.0"/>
                    <TextField fx:id="gradeField" promptText="Grade (e.g., A+)" prefWidth="120.0"/>
                    <Region HBox.hgrow="ALWAYS" />
                    <Button onAction="#handleAssignGrade" minWidth="-Infinity" styleClass="button" text="Submit Final Grade" />
                </HBox>

                <VBox spacing="10.0" styleClass="card">
                    <Label text="Send Feedback to Student" style="-fx-font-weight: bold; -fx-text-fill: #0f172a; -fx-font-size: 18px;"/>
                    <HBox alignment="CENTER_LEFT" spacing="10.0">
                        <Label text="Selected Student:" minWidth="-Infinity" style="-fx-font-weight: bold; -fx-text-fill: #64748b;"/>
                        <Label fx:id="selectedStudentLabel" text="None" minWidth="-Infinity" style="-fx-text-fill: #3b82f6; -fx-font-weight: bold;"/>
                        <Region HBox.hgrow="ALWAYS" />
                    </HBox>
                    <HBox alignment="CENTER_LEFT" spacing="15.0">
                        <TextField fx:id="feedbackField" promptText="Write your feedback here..." HBox.hgrow="ALWAYS"/>
                        <Button onAction="#handleSubmitFeedback" minWidth="-Infinity" styleClass="btn-success" text="Send Feedback" />
                    </HBox>
                </VBox>

                <VBox spacing="10.0" styleClass="card">
                    <Label text="Feedback Received from Students" style="-fx-font-weight: bold; -fx-text-fill: #0f172a; -fx-font-size: 18px;"/>
                    <TableView fx:id="feedbackTable" prefHeight="200.0">
                        <columns>
                            <TableColumn fx:id="colFeedbackFrom" text="From Student" />
                            <TableColumn fx:id="colFeedbackMessage" text="Feedback" />
                            <TableColumn fx:id="colFeedbackDate" text="Date Received" />
                        </columns>
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                        </columnResizePolicy>
                    </TableView>
                </VBox>

            </VBox>
        </ScrollPane>
    </center>
</BorderPane>