<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.edutrack.controller.AdminDashboardController">

    <left>
        <VBox prefWidth="220.0" spacing="30.0" styleClass="sidebar">
            <padding>
                <Insets bottom="30.0" left="25.0" right="25.0" top="40.0"/>
            </padding>
            <Label text="EduTrack" styleClass="sidebar-title" />
            <Label text="Admin Portal" style="-fx-text-fill: #94a3b8; -fx-font-size: 14px;" />
            
            <Region VBox.vgrow="ALWAYS"/>
            
            <Button maxWidth="Infinity" onAction="#handleLogout" styleClass="btn-danger" text="Logout" />
        </VBox>
    </left>

    <center>
        <VBox spacing="25.0">
            <padding>
                <Insets bottom="40.0" left="40.0" right="40.0" top="40.0"/>
            </padding>

            <Label text="System Administration" style="-fx-font-size: 32px; -fx-font-weight: 800; -fx-text-fill: #1e293b;"/>

            <VBox VBox.vgrow="ALWAYS" spacing="10.0" styleClass="card">
                <HBox alignment="CENTER_LEFT">
                    <Label text="User Management" style="-fx-font-weight: bold; -fx-text-fill: #0f172a; -fx-font-size: 18px;"/>
                    <Region HBox.hgrow="ALWAYS" />
                    <Button onAction="#handleDeleteUser" minWidth="-Infinity" styleClass="btn-danger" text="Delete Selected User" />
                </HBox>
                
                <TableView fx:id="userTable" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colId" maxWidth="80.0" minWidth="50.0" text="ID" />
                        <TableColumn fx:id="colName" text="Full Name" />
                        <TableColumn fx:id="colEmail" text="Email Address" />
                        <TableColumn fx:id="colRole" text="Account Role" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>
            </VBox>

            <VBox spacing="15.0" styleClass="card">
                <Label text="Register New User" style="-fx-font-weight: bold; -fx-text-fill: #0f172a; -fx-font-size: 18px;"/>
                <HBox spacing="15.0" alignment="CENTER_LEFT">
                    <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                        <TextField fx:id="nameField" promptText="Full Name"/>
                    </VBox>
                    <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                        <TextField fx:id="emailField" promptText="Email Address"/>
                    </VBox>
                    <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                        <PasswordField fx:id="passwordField" promptText="Password"/>
                    </VBox>
                    <VBox spacing="5.0">
                        <ComboBox fx:id="roleComboBox" promptText="Role" prefWidth="120.0"/>
                    </VBox>
                    <Button onAction="#handleAddUser" minWidth="-Infinity" styleClass="btn-success" text="Add User" />
                </HBox>
            </VBox>
        </VBox>
    </center>
</BorderPane>