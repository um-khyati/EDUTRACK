<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.edutrack.controller.LoginController">

    <VBox alignment="CENTER" maxWidth="400.0" spacing="20.0" styleClass="card">
        <padding>
            <Insets bottom="40.0" left="40.0" right="40.0" top="40.0"/>
        </padding>

        <Label text="EduTrack" style="-fx-font-size: 36px; -fx-font-weight: 900; -fx-text-fill: #3b82f6;"/>
        <Label text="Welcome back! Please login to your account." style="-fx-text-fill: #64748b; -fx-font-size: 14px;"/>
        
        <VBox spacing="25.0" style="-fx-padding: 20 0 0 0;">
            <VBox spacing="8.0">
                <Label text="Email Address" style="-fx-font-weight: bold; -fx-text-fill: #475569;"/>
                <TextField fx:id="emailField" promptText="Enter your email" style="-fx-pref-height: 40px;"/>
            </VBox>
            
            <VBox spacing="8.0">
                <Label text="Password" style="-fx-font-weight: bold; -fx-text-fill: #475569;"/>
                <PasswordField fx:id="passwordField" promptText="Enter your password" style="-fx-pref-height: 40px;"/>
            </VBox>
            
            <Label fx:id="errorLabel" textFill="#ef4444" style="-fx-font-weight: bold;" wrapText="true"/>
            
            <Button maxWidth="Infinity" onAction="#handleLogin" styleClass="button" style="-fx-pref-height: 45px; -fx-font-size: 16px;" text="Sign In" />
        </VBox>
    </VBox>

</VBox>