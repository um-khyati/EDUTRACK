<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.edutrack.controller.StudentDashboardController">
    
    <left>
        <VBox prefWidth="220.0" spacing="30.0" styleClass="sidebar">
            <padding>
                <Insets bottom="30.0" left="25.0" right="25.0" top="40.0"/>
            </padding>
            <Label text="EduTrack" styleClass="sidebar-title" />
            <Region VBox.vgrow="ALWAYS"/>
            <Button maxWidth="Infinity" onAction="#handleLogout" styleClass="btn-danger" text="Logout" />
        </VBox>
    </left>

    <center>
        <ScrollPane fitToWidth="true" style="-fx-faint-focus-color: transparent; -fx-focus-color: transparent;">
            <VBox spacing="25.0">
                <padding>
                    <Insets bottom="40.0" left="40.0" right="40.0" top="40.0"/>
                </padding>
                
                <Label fx:id="welcomeLabel" text="Student Dashboard" style="-fx-font-size: 32px; -fx-font-weight: 800; -fx-text-fill: #1e293b;"/>

                <HBox alignment="CENTER_LEFT" spacing="15.0" styleClass="card">
                    <Label text="Enrolled Course: " minWidth="-Infinity" style="-fx-font-weight: bold; -fx-text-fill: #64748b; -fx-font-size: 15px;"/>
                    <Label fx:id="courseLabel" text="Loading..." minWidth="-Infinity" style="-fx-text-fill: #3b82f6; -fx-font-weight: bold; -fx-font-size: 16px;"/>
                    <Region HBox.hgrow="ALWAYS" />
                    <TextField fx:id="courseInputField" promptText="Update course..." prefWidth="250.0"/>
                    <Button onAction="#handleUpdateCourse" minWidth="-Infinity" styleClass="btn-warning" text="Update Course" />
                </HBox>

                <VBox spacing="10.0" styleClass="card">
                    <Label text="Recent Attendance" style="-fx-font-weight: bold; -fx-text-fill: #0f172a; -fx-font-size: 18px;"/>
                    <TableView fx:id="attendanceTable" prefHeight="200.0">
                        <columns>
                            <TableColumn fx:id="colDate" text="Date" />
                            <TableColumn fx:id="colStatus" text="Status" />
                        </columns>
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                        </columnResizePolicy>
                    </TableView>
                </VBox>

                <VBox spacing="10.0" styleClass="card">
                    <Label text="Academic Performance" style="-fx-font-weight: bold; -fx-text-fill: #0f172a; -fx-font-size: 18px;"/>
                    <TableView fx:id="gradeTable" prefHeight="200.0">
                        <columns>
                            <TableColumn fx:id="colSubject" text="Subject / Course Name" />
                            <TableColumn fx:id="colGradeValue" text="Final Grade" />
                        </columns>
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                        </columnResizePolicy>
                    </TableView>
                </VBox>

                <VBox spacing="10.0" styleClass="card">
                    <Label text="Send Feedback to Teacher" style="-fx-font-weight: bold; -fx-text-fill: #0f172a; -fx-font-size: 18px;"/>
                    <HBox alignment="CENTER_LEFT" spacing="15.0">
                        <ComboBox fx:id="teacherComboBox" promptText="Select Teacher..." prefWidth="200.0"/>
                        <TextField fx:id="studentFeedbackField" promptText="Write your feedback here..." HBox.hgrow="ALWAYS"/>
                        <Button onAction="#handleSubmitFeedback" minWidth="-Infinity" styleClass="btn-primary" text="Submit Feedback" />
                    </HBox>
                </VBox>

                <VBox spacing="10.0" styleClass="card">
                    <Label text="Feedback from Teachers" style="-fx-font-weight: bold; -fx-text-fill: #0f172a; -fx-font-size: 18px;"/>
                    <TableView fx:id="feedbackTable" prefHeight="200.0">
                        <columns>
                            <TableColumn fx:id="colFeedbackFrom" text="From Teacher" />
                            <TableColumn fx:id="colFeedbackMessage" text="Feedback" />
                            <TableColumn fx:id="colFeedbackDate" text="Date Received" />
                        </columns>
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                        </columnResizePolicy>
                    </TableView>
                </VBox>
            </VBox>
        </ScrollPane>
    </center>
</BorderPane>